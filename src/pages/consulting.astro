---
import RootLayout from "../layouts/RootLayout.astro";
import { roles } from "../data/roles";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.owntube.tv/consulting#page",
      name: "Expert Consulting — OwnTube.tv",
      url: "https://www.owntube.tv/consulting",
      description:
        "OwnTube Nordic AB provides expert consulting in video-on-demand streaming, large-scale IT infrastructure, software development, DevSecOps, container platforms, AI tools, and authentication systems.",
      isPartOf: { "@id": "https://www.owntube.tv/#website" },
      about: { "@id": "https://www.owntube.tv/#consulting-service" },
    },
    {
      "@type": "ProfessionalService",
      "@id": "https://www.owntube.tv/#consulting-service",
      name: "OwnTube Expert Consulting",
      provider: { "@id": "https://www.owntube.tv/#organization" },
      url: "https://www.owntube.tv/consulting",
      description:
        "Comprehensive consulting services in video-on-demand (VoD) streaming and large-scale IT infrastructure. Whether you're looking to self-host or leverage cloud solutions, our team can guide you through your video streaming journey.",
      serviceType: "IT Consulting",
      areaServed: "Worldwide",
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Consulting Roles",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Lead Developer",
              description:
                "Technical leadership and hands-on development for video streaming applications and backend infrastructure.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Tech Lead & Architect",
              description:
                "Strategic technical direction, solution design, and team leadership for video streaming projects.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Frontend Development",
              description: "Expert React frontend development for video applications on web, mobile and TV.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Infrastructure Architect",
              description:
                "Design and implementation of scalable infrastructure for video delivery and containerized workloads.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "DevSecOps",
              description:
                "Secure and efficient CI/CD pipelines for a multitude of use cases, from mobile apps to infrastructure deployments.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Backend Development",
              description:
                "Robust backend systems for edge deployments, strong authentication, data persistence, and content management.",
            },
          },
        ],
      },
    },
  ],
};
---

<RootLayout
  title="Expert Consulting — OwnTube.tv"
  description="OwnTube Nordic AB provides expert consulting in video-on-demand streaming, large-scale IT infrastructure, software development, DevSecOps, container platforms, AI tools, and authentication systems."
  canonicalPath="/consulting"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <div class="min-h-screen">
    <div class="container mx-auto px-4 py-12">
      <h1 class="text-4xl font-bold mb-8">Expert Consulting</h1>

      <div class="bg-owntube-light rounded-lg p-8 mb-12">
        <h2 class="text-2xl font-bold mb-4">Our Expertise</h2>
        <p class="text-lg mb-4">
          With years of experience in video-on-demand (VoD) streaming and large-scale IT infrastructure, we provide
          comprehensive consulting services to help you succeed.
        </p>
        <p class="text-lg mb-4">
          Whether you're looking to self-host or leverage cloud solutions, our team can guide you through your video
          streaming journey. We also offer a wide range of expertise in software development, automation practices,
          container platforms, AI tools, authentication and authorization, and many other areas.
        </p>
        <p class="text-lg mb-4">
          Feel free to get in touch at <a href="mailto:hello@owntube.tv" class="text-owntube-orange hover:underline"
            >hello@owntube.tv</a
          >!
        </p>
      </div>

      <h2 class="text-2xl font-bold mb-6">Roles We Can Fill</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          roles.map((role) => (
            <div class="bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold mb-2 text-owntube-orange">{role.title}</h3>
              <p class="text-gray-600">{role.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</RootLayout>
