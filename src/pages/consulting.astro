---
import RootLayout from "../layouts/RootLayout.astro";
import { roles } from "../data/roles";
---

<RootLayout
  title="Expert Consulting — OwnTube.tv"
  description="OwnTube Nordic AB provides expert consulting in video-on-demand streaming, large-scale IT infrastructure, software development, DevSecOps, container platforms, AI tools, and authentication systems."
  canonicalPath="/consulting"
>
  <div class="min-h-screen">
    <div class="container mx-auto px-4 py-12">
      <h1 class="text-4xl font-bold mb-8">Expert Consulting</h1>

      <div class="bg-owntube-light rounded-lg p-8 mb-12">
        <h2 class="text-2xl font-bold mb-4">Our Expertise</h2>
        <p class="text-lg mb-4">
          With years of experience in video-on-demand (VoD) streaming and large-scale IT infrastructure, we provide
          comprehensive consulting services to help you succeed.
        </p>
        <p class="text-lg mb-4">
          Whether you're looking to self-host or leverage cloud solutions, our team can guide you through your video
          streaming journey. We also offer a wide range of expertise in software development, automation practices,
          container platforms, AI tools, authentication and authorization, and many other areas.
        </p>
        <p class="text-lg mb-4">
          Feel free to get in touch at <a href="mailto:hello@owntube.tv" class="text-owntube-orange hover:underline"
            >hello@owntube.tv</a
          >!
        </p>
      </div>

      <h2 class="text-2xl font-bold mb-6">Roles We Can Fill</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          roles.map((role) => (
            <div class="bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold mb-2 text-owntube-orange">{role.title}</h3>
              <p class="text-gray-600">{role.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</RootLayout>
