---
import RootLayout from "../layouts/RootLayout.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.owntube.tv/contact#page",
      name: "Contact Us — OwnTube.tv",
      url: "https://www.owntube.tv/contact",
      description: "Contact OwnTube Nordic AB. Located in Stockholm, Sweden.",
      isPartOf: { "@id": "https://www.owntube.tv/#website" },
      about: { "@id": "https://www.owntube.tv/#organization" },
    },
    {
      "@type": "Organization",
      "@id": "https://www.owntube.tv/#organization",
      name: "OwnTube Nordic AB",
      legalName: "OwnTube Nordic AB",
      url: "https://www.owntube.tv",
      email: "hello@owntube.tv",
      telephone: "+46730567567",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Älgpassgatan 12 lgh 1102",
        postalCode: "11545",
        addressLocality: "Stockholm",
        addressCountry: "SE",
      },
      vatID: "SE559517719601",
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer support",
        email: "hello@owntube.tv",
        telephone: "+46730567567",
      },
    },
  ],
};
---

<RootLayout
  title="Contact Us — OwnTube.tv"
  description="Contact OwnTube Nordic AB. Located in Stockholm, Sweden."
  canonicalPath="/contact"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <div class="min-h-screen">
    <div class="container mx-auto px-4 py-12">
      <h1 class="text-4xl font-bold mb-8">Contact Us</h1>

      <div class="bg-white rounded-lg shadow-lg p-8 max-w-2xl mx-auto">
        <div class="space-y-6">
          <div>
            <h2 class="text-2xl font-bold mb-4">Company Information</h2>
            <div class="space-y-3">
              <p><span class="font-semibold">Legal Name:</span> OwnTube Nordic AB</p>
              <p><span class="font-semibold">VAT Number:</span> SE559517719601</p>
              <p>
                <span class="font-semibold">Address:</span> Älgpassgatan 12 lgh 1102, 11545 Stockholm, SWEDEN
              </p>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold mb-4">Get in Touch</h2>
            <div class="space-y-3">
              <p>
                <span class="font-semibold">Phone:</span>
                <a href="tel:+46730567567" class="text-owntube-orange hover:underline">+46 730 567 567</a>
              </p>
              <p>
                <span class="font-semibold">Email:</span>
                <a href="mailto:hello@owntube.tv" class="text-owntube-orange hover:underline">hello@owntube.tv</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</RootLayout>
